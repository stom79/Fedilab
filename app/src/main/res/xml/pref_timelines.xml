<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_REMEMBER_POSITION"
        app:singleLineTitle="false"
        app:title="@string/remember_position" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        app:iconSpaceReserved="false"
        app:key="@string/SET_AUTO_FETCH_MISSING_MESSAGES"
        app:singleLineTitle="false"
        app:title="@string/auto_fetch_missing" />
    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_GROUP_REBLOGS"
        app:singleLineTitle="false"
        app:title="@string/group_reblogs" />
    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_CHAT_FOR_CONVERSATION"
        app:singleLineTitle="false"
        app:title="@string/chat_timeline_for_direct" />
    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_BOOST_ORIGINAL_DATE"
        app:singleLineTitle="false"
        app:title="@string/boost_original_date" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        app:iconSpaceReserved="false"
        app:key="@string/SET_TIMELINE_SCROLLBAR"
        app:singleLineTitle="false"
        app:title="@string/timeline_scrollbar" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        app:iconSpaceReserved="false"
        app:key="@string/SET_REVERSE_TIMELINE"
        app:singleLineTitle="false"
        app:title="@string/reverse_timeline" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        android:dependency="@string/SET_REVERSE_TIMELINE"
        app:iconSpaceReserved="false"
        app:key="@string/SET_COMPOSE_TOP_REVERSE"
        app:singleLineTitle="false"
        app:title="@string/compose_top_reverse" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        app:iconSpaceReserved="false"
        app:key="@string/SET_REFRESH_ALL_TIMELINES"
        app:singleLineTitle="false"
        app:summary="@string/refresh_all_timelines_summary"
        app:title="@string/refresh_all_timelines" />
    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_HIGHLIGHT_NEW_COMMENTS"
        app:singleLineTitle="false"
        app:title="@string/highlight_new_comments" />

    <androidx.preference.SeekBarPreference
        android:defaultValue="5"
        android:max="40"
        app:iconSpaceReserved="false"
        app:key="@string/SET_MAX_INDENTATION"
        app:showSeekBarValue="true"
        app:singleLineTitle="false"
        app:title="@string/max_indentation_thread" />

    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_NOTIF_VALIDATION"
        app:singleLineTitle="false"
        app:title="@string/set_share_validation" />
    <SwitchPreferenceCompat
        app:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_MANDATORY_ALT_TEXT_FOR_BOOSTS"
        app:singleLineTitle="false"
        app:title="@string/warn_boost_no_media_description" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        app:iconSpaceReserved="false"
        app:key="@string/SET_NOTIF_VALIDATION_FAV"
        app:singleLineTitle="false"
        app:title="@string/set_share_validation_fav" />
    <SwitchPreferenceCompat
        android:defaultValue="false"
        app:iconSpaceReserved="false"
        app:key="@string/SET_DISPLAY_COUNTER_FAV_BOOST"
        app:singleLineTitle="false"
        app:title="@string/set_display_counter" />
    <SwitchPreferenceCompat
        android:defaultValue="true"
        app:iconSpaceReserved="false"
        app:key="@string/SET_DISPLAY_BOOKMARK"
        app:singleLineTitle="false"
        app:title="@string/set_display_bookmark_indication" />
    <ListPreference
        android:entries="@array/set_quote_button_entries"
        android:entryValues="@array/set_quote_button_entry_values"
        android:title="@string/set_display_quote_indication"
        app:icon="@drawable/ic_baseline_format_quote_24"
        app:key="@string/SET_QUOTE_BUTTON"
        app:useSimpleSummaryProvider="true" />

    <androidx.preference.SeekBarPreference
        android:defaultValue="40"
        app:min="10"
        android:max="80"
        app:iconSpaceReserved="false"
        app:key="@string/SET_STATUSES_PER_CALL"
        app:showSeekBarValue="true"
        app:title="@string/set_toots_page" />

    <androidx.preference.SeekBarPreference
        android:defaultValue="40"
        app:min="10"
        android:max="80"
        app:iconSpaceReserved="false"
        app:key="@string/SET_ACCOUNTS_PER_CALL"
        app:showSeekBarValue="true"
        app:title="@string/set_accounts_page" />
</androidx.preference.PreferenceScreen>
